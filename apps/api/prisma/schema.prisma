datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  ADMIN
  MANAGER
  EMPLOYEE
  HR
}

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  password       String
  role           UserRole  @default(EMPLOYEE)
  isActive       Boolean   @default(true)
  failedAttempts Int       @default(0)
  lockoutUntil   DateTime?
  resetToken     String?
  resetTokenExp  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?
  firstName      String?
  lastName       String?
  avatarUrl      String?

  employee           Employee?
  auditLogs          AuditLog[]
  notifications      Notification[]
  createdRecruitments Recruitment[] @relation("CreatedRecruitments")

  @@map("users")
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  SUSPENDED
}

model Employee {
  id              String         @id @default(uuid())
  firstName       String
  lastName        String
  email           String         @unique
  phone           String
  status          EmployeeStatus @default(ACTIVE)
  hireDate        DateTime
  terminationDate DateTime?
  salary          Decimal        @db.Decimal(10, 2)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?

  // Relations
  userId       String?     @unique
  user         User?       @relation(fields: [userId], references: [id])
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  positionId   String?
  position     Position?   @relation(fields: [positionId], references: [id])
  vacations         Vacation[]
  leaves            Leave[]
  documents         Document[]

  timeSchedule      TimeSchedule?
  timeRecords       TimeRecord[]
  timeSummaries     TimeDaySummary[]
  hourBankLedger    HourBankLedger[]
  corrections       TimeCorrectionRequest[]
  overtimeRequests  OvertimeApprovalRequest[]

  personalData      EmployeePersonalData?
  address           EmployeeAddress?
  bankAccount       EmployeeBankAccount?
  emergencyContacts EmergencyContact[]

  managedDepartments Department[] @relation("DepartmentManager")

  @@map("employees")
}

model EmployeePersonalData {
  id           String    @id @default(uuid())
  employeeId   String    @unique
  employee     Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  cpf          String    @unique
  rg           String?
  birthDate    DateTime
  gender       String?
  maritalStatus String?
  avatarUrl    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("employee_personal_data")
}

model EmployeeAddress {
  id           String   @id @default(uuid())
  employeeId   String   @unique
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  cep          String
  street       String
  number       String
  complement   String?
  neighborhood String
  city         String
  state        String   @db.VarChar(2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("employee_addresses")
}

model EmployeeBankAccount {
  id          String   @id @default(uuid())
  employeeId  String   @unique
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  bankCode    String
  bankAgency  String
  bankAccount String
  accountType String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("employee_bank_accounts")
}

model EmergencyContact {
  id           String   @id @default(uuid())
  employeeId   String
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  name         String
  phone        String
  relationship String
  isPrimary    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("emergency_contacts")
}

model Department {
  id          String    @id @default(uuid())
  name        String    @unique
  code        String    @unique
  description String?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  // Relations
  managerId    String?
  manager      Employee?     @relation("DepartmentManager", fields: [managerId], references: [id])
  employees    Employee[]
  positions    Position[]
  recruitments Recruitment[]

  @@map("departments")
}

model Position {
  id             String    @id @default(uuid())
  title          String
  description    String?
  salaryRangeMin Decimal   @db.Decimal(10, 2)
  salaryRangeMax Decimal   @db.Decimal(10, 2)
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  // Relations
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])
  employees    Employee[]
  recruitments Recruitment[]

  @@map("positions")
}

enum VacationStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model Vacation {
  id              String         @id @default(uuid())
  startDate       DateTime
  endDate         DateTime
  status          VacationStatus @default(PENDING)
  rejectionReason String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?

  // Relations
  employeeId   String
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  approvedById String?

  @@map("vacations")
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum LeaveType {
  MEDICAL
  PARENTAL
  LEGAL
  UNPAID
  OTHER
}

model Leave {
  id              String      @id @default(uuid())
  startDate       DateTime
  endDate         DateTime
  type            LeaveType
  customType      String?
  description     String?
  status          LeaveStatus @default(PENDING)
  rejectionReason String?
  attachmentUrl   String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?

  // Relations
  employeeId   String
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  approvedById String?

  @@map("leaves")
}

model Document {
  id        String    @id @default(uuid())
  name      String
  type      String
  url       String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  @@map("documents")
}

enum RecruitmentStatus {
  DRAFT
  OPEN
  PAUSED
  CLOSED
  FILLED
}

enum EmploymentType {
  CLT
  PJ
  INTERNSHIP
  TRAINEE
  TEMPORARY
}

enum WorkModel {
  ONSITE
  HYBRID
  REMOTE
}

enum Seniority {
  INTERN
  JUNIOR
  MID
  SENIOR
  LEAD
  SPECIALIST
}

model Recruitment {
  id               String            @id @default(uuid())
  title            String
  slug             String            @unique
  description      String
  status           RecruitmentStatus @default(DRAFT)
  employmentType   EmploymentType
  workModel        WorkModel
  seniority        Seniority
  vacancies        Int               @default(1)
  salaryMin        Decimal?          @db.Decimal(10, 2)
  salaryMax        Decimal?          @db.Decimal(10, 2)
  isSalaryVisible  Boolean           @default(false)
  city             String?
  state            String?
  country          String?           @default("Brasil")
  requirements     String?
  responsibilities String?
  benefits         String?
  views            Int               @default(0)
  publishedAt      DateTime?
  expiresAt        DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deletedAt        DateTime?

  // Relations
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])
  positionId   String
  position     Position   @relation(fields: [positionId], references: [id])
  createdById  String
  createdBy    User       @relation("CreatedRecruitments", fields: [createdById], references: [id])
  applications Application[]

  @@index([status])
  @@index([slug])
  @@index([publishedAt])
  @@index([departmentId])
  @@map("recruitments")
}

model Candidate {
  id             String    @id @default(uuid())
  firstName      String
  lastName       String
  email          String    @unique
  phone          String
  linkedinUrl    String?
  githubUrl      String?
  portfolioUrl   String?
  currentSalary  Decimal?  @db.Decimal(10, 2)
  expectedSalary Decimal?  @db.Decimal(10, 2)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  // Relations
  applications Application[]

  @@index([createdAt])
  @@map("candidates")
}

enum ApplicationStatus {
  SCREENING
  HR_INTERVIEW
  TECHNICAL_TEST
  OFFER
  HIRED
  REJECTED
}

model Application {
  id            String            @id @default(uuid())
  resumeUrl     String
  coverLetter   String?
  status        ApplicationStatus @default(SCREENING)
  feedback      String?
  hiredAt       DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  deletedAt     DateTime?

  // Relations
  recruitmentId String
  recruitment   Recruitment @relation(fields: [recruitmentId], references: [id], onDelete: Cascade)
  candidateId   String
  candidate     Candidate   @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@unique([candidateId, recruitmentId])
  @@index([status])
  @@index([recruitmentId])
  @@map("job_applications")
}

model Notification {
  id        String   @id @default(uuid())
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  // Relations
  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  details   String
  timestamp DateTime @default(now())

  // Relations
  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model TimeSchedule {
  id               String   @id @default(uuid())
  employeeId       String   @unique
  expectedIn       String   // ex: "08:00"
  expectedOut      String   // ex: "17:00"
  intervalMinutes  Int      @default(60)
  workDays         Int[]    // ex: [1, 2, 3, 4, 5] (Segunda a Sexta)
  toleranceMinutes Int      @default(10)
  employee         Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("time_schedules")
}

enum TimeRecordType {
  ENTRY
  INTERVAL_OUT
  INTERVAL_IN
  EXIT
}

enum TimeRecordSource {
  WEB
  MOBILE
  ADMIN
}

model TimeRecord {
  id          String           @id @default(uuid())
  employeeId  String
  timestamp   DateTime
  type        TimeRecordType
  source      TimeRecordSource
  ipAddress   String?
  userAgent   String?
  latitude    Float?
  longitude   Float?
  comments    String?
  createdAt   DateTime         @default(now())
  employee    Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("time_records")
}

model TimeDaySummary {
  id              String   @id @default(uuid())
  employeeId      String
  date            DateTime // Apenas data (Y-m-d)
  grossMinutes    Int      // Minutos trabalhados brutos
  intervalMinutes Int      // Minutos de intervalo real
  netMinutes      Int      // Minutos trabalhados líquidos
  expectedMinutes Int      // Minutos que deveria trabalhar
  overtimeMinutes Int      // Horas extras geradas
  debtMinutes     Int      // Horas devidas/atraso
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@map("time_day_summaries")
}

model HourBankLedger {
  id         String   @id @default(uuid())
  employeeId String
  date       DateTime
  amount     Int      // Saldo positivo (crédito) ou negativo (débito) em minutos
  reason     String   // ex: "Horas extras da jornada" ou "Falta injustificada"
  balance    Int      // Saldo acumulado do funcionário após a transação
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("hour_bank_ledgers")
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model TimeCorrectionRequest {
  id          String         @id @default(uuid())
  employeeId  String
  date        DateTime
  targetType  TimeRecordType
  time        String         // ex: "08:15"
  reason      String
  status      RequestStatus  @default(PENDING)
  notes       String?        // Observações do gestor
  employee    Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("time_correction_requests")
}

model OvertimeApprovalRequest {
  id              String        @id @default(uuid())
  employeeId      String
  date            DateTime
  minutesExceeded Int
  status          RequestStatus @default(PENDING)
  notes           String?
  employee        Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("overtime_approval_requests")
}

