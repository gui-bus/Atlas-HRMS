datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  ADMIN
  MANAGER
  EMPLOYEE
  HR
}

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  password       String
  role           UserRole  @default(EMPLOYEE)
  isActive       Boolean   @default(true)
  failedAttempts Int       @default(0)
  lockoutUntil   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  employee           Employee?
  auditLogs          AuditLog[]
  notifications      Notification[]
  createdRecruitments Recruitment[] @relation("CreatedRecruitments")

  @@map("users")
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  SUSPENDED
}

model Employee {
  id              String         @id @default(uuid())
  firstName       String
  lastName        String
  email           String         @unique
  phone           String
  status          EmployeeStatus @default(ACTIVE)
  hireDate        DateTime
  terminationDate DateTime?
  salary          Decimal        @db.Decimal(10, 2)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?

  // Relations
  userId       String?     @unique
  user         User?       @relation(fields: [userId], references: [id])
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  positionId   String?
  position     Position?   @relation(fields: [positionId], references: [id])
  vacations         Vacation[]
  leaves            Leave[]
  documents         Document[]

  personalData      EmployeePersonalData?
  address           EmployeeAddress?
  bankAccount       EmployeeBankAccount?
  emergencyContacts EmergencyContact[]

  managedDepartments Department[] @relation("DepartmentManager")

  @@map("employees")
}

model EmployeePersonalData {
  id           String    @id @default(uuid())
  employeeId   String    @unique
  employee     Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  cpf          String    @unique
  rg           String?
  birthDate    DateTime
  gender       String?
  maritalStatus String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("employee_personal_data")
}

model EmployeeAddress {
  id           String   @id @default(uuid())
  employeeId   String   @unique
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  cep          String
  street       String
  number       String
  complement   String?
  neighborhood String
  city         String
  state        String   @db.VarChar(2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("employee_addresses")
}

model EmployeeBankAccount {
  id          String   @id @default(uuid())
  employeeId  String   @unique
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  bankCode    String
  bankAgency  String
  bankAccount String
  accountType String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("employee_bank_accounts")
}

model EmergencyContact {
  id           String   @id @default(uuid())
  employeeId   String
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  name         String
  phone        String
  relationship String
  isPrimary    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("emergency_contacts")
}

model Department {
  id          String    @id @default(uuid())
  name        String    @unique
  code        String    @unique
  description String?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  // Relations
  managerId    String?
  manager      Employee?     @relation("DepartmentManager", fields: [managerId], references: [id])
  employees    Employee[]
  positions    Position[]
  recruitments Recruitment[]

  @@map("departments")
}

model Position {
  id             String    @id @default(uuid())
  title          String
  description    String?
  salaryRangeMin Decimal   @db.Decimal(10, 2)
  salaryRangeMax Decimal   @db.Decimal(10, 2)
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  // Relations
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])
  employees    Employee[]
  recruitments Recruitment[]

  @@map("positions")
}

enum VacationStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model Vacation {
  id              String         @id @default(uuid())
  startDate       DateTime
  endDate         DateTime
  status          VacationStatus @default(PENDING)
  rejectionReason String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?

  // Relations
  employeeId   String
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  approvedById String?

  @@map("vacations")
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum LeaveType {
  MEDICAL
  PARENTAL
  LEGAL
  UNPAID
  OTHER
}

model Leave {
  id              String      @id @default(uuid())
  startDate       DateTime
  endDate         DateTime
  type            LeaveType
  description     String?
  status          LeaveStatus @default(PENDING)
  rejectionReason String?
  attachmentUrl   String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?

  // Relations
  employeeId   String
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  approvedById String?

  @@map("leaves")
}

model Document {
  id        String    @id @default(uuid())
  name      String
  type      String
  url       String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  @@map("documents")
}

enum RecruitmentStatus {
  DRAFT
  OPEN
  PAUSED
  CLOSED
  FILLED
}

enum EmploymentType {
  CLT
  PJ
  INTERNSHIP
  TRAINEE
  TEMPORARY
}

enum WorkModel {
  ONSITE
  HYBRID
  REMOTE
}

enum Seniority {
  INTERN
  JUNIOR
  MID
  SENIOR
  LEAD
  SPECIALIST
}

model Recruitment {
  id               String            @id @default(uuid())
  title            String
  slug             String            @unique
  description      String
  status           RecruitmentStatus @default(DRAFT)
  employmentType   EmploymentType
  workModel        WorkModel
  seniority        Seniority
  vacancies        Int               @default(1)
  salaryMin        Decimal?          @db.Decimal(10, 2)
  salaryMax        Decimal?          @db.Decimal(10, 2)
  isSalaryVisible  Boolean           @default(false)
  city             String?
  state            String?
  country          String?           @default("Brasil")
  requirements     String?
  responsibilities String?
  benefits         String?
  views            Int               @default(0)
  publishedAt      DateTime?
  expiresAt        DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deletedAt        DateTime?

  // Relations
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])
  positionId   String
  position     Position   @relation(fields: [positionId], references: [id])
  createdById  String
  createdBy    User       @relation("CreatedRecruitments", fields: [createdById], references: [id])
  applications Application[]

  @@index([status])
  @@index([slug])
  @@index([publishedAt])
  @@index([departmentId])
  @@map("recruitments")
}

model Candidate {
  id             String    @id @default(uuid())
  firstName      String
  lastName       String
  email          String    @unique
  phone          String
  linkedinUrl    String?
  githubUrl      String?
  portfolioUrl   String?
  currentSalary  Decimal?  @db.Decimal(10, 2)
  expectedSalary Decimal?  @db.Decimal(10, 2)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  // Relations
  applications Application[]

  @@index([createdAt])
  @@map("candidates")
}

enum ApplicationStatus {
  SUBMITTED
  SCREENING
  HR_INTERVIEW
  TECHNICAL_TEST
  TECHNICAL_INTERVIEW
  FINAL_INTERVIEW
  OFFER
  HIRED
  REJECTED
  WITHDRAWN
}

model Application {
  id            String            @id @default(uuid())
  resumeUrl     String
  coverLetter   String?
  status        ApplicationStatus @default(SUBMITTED)
  feedback      String?
  hiredAt       DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  deletedAt     DateTime?

  // Relations
  recruitmentId String
  recruitment   Recruitment @relation(fields: [recruitmentId], references: [id], onDelete: Cascade)
  candidateId   String
  candidate     Candidate   @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@unique([candidateId, recruitmentId])
  @@index([status])
  @@index([recruitmentId])
  @@map("job_applications")
}

model Notification {
  id        String   @id @default(uuid())
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  // Relations
  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  details   String
  timestamp DateTime @default(now())

  // Relations
  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}
